{
    "version": 2,
    "installCommand": "npm install",
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "src/**",
                    "node_modules/mysql2/**",
                    "node_modules/seq*/**",
                    "node_modules/lru-cache/**",
                    "node_modules/iconv-lite/**",
                    "node_modules/long/**",
                    "node_modules/named-placeholders/**",
                    "node_modules/generate-function/**",
                    "node_modules/sqlstring/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.js"
        }
    ]
}